{
  "name": "@akronae/logger",
  "version": "0.0.7",
  "repository": "git@github.com:akronae/logger.git",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/src/index.cjs",
  "module": "./dist/src/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.cjs"
      },
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.mjs"
      }
    },
    "./*": {
      "require": {
        "types": "./*.d.ts",
        "default": "./*.cjs"
      },
      "import": {
        "types": "./*.d.ts",
        "default": "./*.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsx ./scripts/build.ts",
    "lint": "prettier --log-level silent --write . && eslint . --fix",
    "prepare": "yarn husky",
    "test": "vitest run --reporter verbose",
    "v:major": "npm version major -m \"chore: bump major to %s\"",
    "v:minor": "npm version minor -m \"chore: bump minor to %s\"",
    "v:patch": "npm version patch -m \"chore: bump patch to %s\""
  },
  "dependencies": {
    "winston": "3.18.3",
    "winston-loki": "6.1.3"
  },
  "devDependencies": {
    "@commitlint/cli": "20.1.0",
    "@commitlint/config-conventional": "20.0.0",
    "@commitlint/types": "20.0.0",
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "dotenv": "17.3.1",
    "esbuild": "0.27.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "prettier": "3.6.2",
    "tsc-alias": "1.8.16",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.47.0",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.13"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
